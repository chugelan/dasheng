{
  "tasks": [
    {
      "id": "order-monitor",
      "name": "订单监控",
      "description": "监控 12301 平台下游失败订单，数据去重不重复通知",
      "type": "script",
      "schedule": "*/10 * * * *",
      "script": "tasks/order-monitor-enhanced.js",
      "enabled": true,
      "config": {
        "timeout": 120000,
        "notifyOnSuccess": true,
        "notifyOnFailure": true,
        "deduplication": true
      }
    },
    {
      "id": "procurement",
      "name": "景区采购",
      "description": "在 12301 资源中心采购指定景点，每天 08:00 和 16:00 执行",
      "type": "script",
      "schedule": "0 8,16 * * *",
      "script": "tasks/procurement.js",
      "enabled": true,
      "config": {
        "timeout": 180000,
        "notifyOnStart": true,
        "notifyOnSuccess": true,
        "notifyOnFailure": true,
        "screenshot": {
          "enabled": true,
          "retentionHours": 2
        },
        "feishuCommand": {
          "trigger": "/procurement",
          "actions": ["run", "status", "help"]
        }
      }
    },
    {
      "id": "sync-scenic",
      "name": "景点同步",
      "description": "同步票付通数据 + 刷新门票价格，每天 08:00 和 16:00 执行",
      "type": "script",
      "schedule": "0 8,16 * * *",
      "script": "tasks/sync-scenic.js",
      "enabled": true,
      "config": {
        "timeout": 300000,
        "notifyOnStart": true,
        "notifyOnSuccess": true,
        "notifyOnFailure": true,
        "screenshot": {
          "enabled": true,
          "retentionHours": 2
        },
        "stealth": true,
        "feishuCommand": {
          "trigger": "/sync-scenic",
          "actions": ["run", "status", "help"]
        }
      }
    }
  ]
}
